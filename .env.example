# Copy to .env and fill in. .env is git-ignored.

# ── Telegram (primary channel, required) ──────────────────────────────────────
# 1) Message @BotFather on Telegram → /newbot → copy the token here.
# 2) Have Karin open the bot and tap Start.
# 3) Run:  python -m arch_job_bot.alert.telegram <TOKEN>   (or: python run.py then check logs)
#    to print her chat_id, and paste it below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # Karin — receives JOB alerts + the weekly digest
# Operational messages (source-down health alerts, daily heartbeat, errors) go here
# instead of Karin's chat. Set to your own chat_id. If blank, ops messages fall back
# to Karin's chat. (Tip: python -m arch_job_bot.alert.telegram <TOKEN> prints chat_ids.)
TELEGRAM_ADMIN_CHAT_ID=

# ── Email (optional free secondary + audit log) ───────────────────────────────
# Leave blank to disable. For Gmail, SMTP_PASSWORD must be an App Password.
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Paths (optional overrides) ────────────────────────────────────────────────
# ARCH_BOT_DATA_DIR=./data
# ARCH_BOT_CONFIG_DIR=./config
